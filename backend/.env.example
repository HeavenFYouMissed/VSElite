# =============================================================================
# V3Code Backend — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# --- Server ---
PORT=8787
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- Postgres ---
# Must have pgvector extension installed: CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgresql://v3code:v3code@localhost:5432/v3code

# --- DeepSeek ---
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_PRO=deepseek-v4-pro
DEEPSEEK_MODEL_FLASH=deepseek-v4-flash

# --- Embeddings (for L2 + L3 semantic cache) ---
# Using OpenAI text-embedding-3-small (1536d) — cheap, fast.
# Swap to a self-hosted bge-small-en-v1.5 once volume justifies it.
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=1536

# --- Cache Tuning ---
CACHE_L1_TTL_SECONDS=604800
CACHE_L1_MAX_BYTES_PER_USER=10737418240
CACHE_L2_COSINE_THRESHOLD=0.93
CACHE_L3_COSINE_THRESHOLD=0.96
CACHE_L3_MIN_OCCURRENCES=20
CACHE_L3_QUARANTINE_HOURS=24
CACHE_L3_ENABLED=false

# --- Auth ---
SESSION_SECRET=__generate_with_openssl_rand_hex_32__
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT=http://localhost:8787/auth/github/callback

# --- Stripe ---
# V3Code-specific products. Created in the V3Code Stripe account (May 2026).
# If you spin up a new Stripe account, replace these with new IDs from the dashboard.
STRIPE_SECRET_KEY=sk_test_51...replace_with_your_own_key
STRIPE_WEBHOOK_SECRET=
# Live price IDs (test or live mode — set STRIPE_SECRET_KEY accordingly):
STRIPE_PRICE_BUILDER=price_1TbX8SGGHOc6OYEsK1dY33Ux
STRIPE_PRICE_PRO=price_1TbXVlGGHOc6OYEsysZ9uQex
STRIPE_PRICE_UNLIMITED=price_1TbX8UGGHOc6OYEsEiwfYYTQ
# Trial days per tier — Stripe-native, no charge during trial. Default matches pricing page.
STRIPE_TRIAL_DAYS_BUILDER=7
STRIPE_TRIAL_DAYS_PRO=7
STRIPE_TRIAL_DAYS_UNLIMITED=0
# Product IDs (for setup:portal script + admin tools; runtime billing doesn't need them).
STRIPE_PRODUCT_BUILDER=prod_UaiZpCY0vLITBC
STRIPE_PRODUCT_PRO=prod_UaixgJds3RjQcX
STRIPE_PRODUCT_UNLIMITED=prod_UaiZgIN3zOH32e
# Customer Portal config ID — required when V3Code shares a Stripe account with other businesses.
# Run `npm run setup:portal` once to create a V3Code-only config; paste the bpc_... id here.
# If unset, backend falls back to the account default portal (works if V3Code has its own account).
STRIPE_PORTAL_CONFIG_ID=

# --- Public URLs ---
PUBLIC_API_URL=http://localhost:8787
PUBLIC_WEB_URL=http://localhost:3000
